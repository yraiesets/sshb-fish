#!/usr/bin/env bash
# ===========================================================================
# sshb - SSH Buddy: A Tamagotchi Terminal Pet
# ===========================================================================
# A persistent virtual pet that lives in your terminal.
# Take care of your buddy between sessions - feed it, play with it,
# let it sleep, and keep it happy and healthy.
#
# v2.0 - Now with blackjack and your cat roasts your failed commands.
# ===========================================================================

set -euo pipefail

SSHB_DIR="${HOME}/.sshb"
STATE_FILE="${SSHB_DIR}/state"
LOG_FILE="${SSHB_DIR}/sshb.log"
LOCK_FILE="${SSHB_DIR}/sshb.lock"
VERSION="2.0.0"

# ---------------------------------------------------------------------------
# Color definitions
# ---------------------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

# ---------------------------------------------------------------------------
# Ensure state directory exists
# ---------------------------------------------------------------------------
init_dir() {
    mkdir -p "${SSHB_DIR}"
}

# ---------------------------------------------------------------------------
# Default state values
# ---------------------------------------------------------------------------
default_state() {
    cat <<'EOF'
PET_NAME=Pixel
PET_TYPE=cat
HUNGER=80
ENERGY=80
HAPPINESS=80
HEALTH=80
AGE_DAYS=0
BORN_EPOCH=0
LAST_FED_EPOCH=0
LAST_SLEPT_EPOCH=0
LAST_PLAYED_EPOCH=0
LAST_UPDATE_EPOCH=0
IS_SLEEPING=0
ALIVE=1
MOOD=happy
TOTAL_FEEDS=0
TOTAL_PLAYS=0
TOTAL_SLEEPS=0
BJ_WINS=0
BJ_LOSSES=0
BJ_PUSHES=0
EOF
}

# ---------------------------------------------------------------------------
# Load or initialize state
# ---------------------------------------------------------------------------
load_state() {
    if [[ ! -f "${STATE_FILE}" ]]; then
        init_dir
        default_state > "${STATE_FILE}"
        local now
        now=$(date +%s)
        sed -i "s/^BORN_EPOCH=.*/BORN_EPOCH=${now}/" "${STATE_FILE}"
        sed -i "s/^LAST_FED_EPOCH=.*/LAST_FED_EPOCH=${now}/" "${STATE_FILE}"
        sed -i "s/^LAST_SLEPT_EPOCH=.*/LAST_SLEPT_EPOCH=${now}/" "${STATE_FILE}"
        sed -i "s/^LAST_PLAYED_EPOCH=.*/LAST_PLAYED_EPOCH=${now}/" "${STATE_FILE}"
        sed -i "s/^LAST_UPDATE_EPOCH=.*/LAST_UPDATE_EPOCH=${now}/" "${STATE_FILE}"
    fi

    # Migrate old state files that lack blackjack stats
    if ! grep -q "^BJ_WINS=" "${STATE_FILE}" 2>/dev/null; then
        echo "BJ_WINS=0" >> "${STATE_FILE}"
        echo "BJ_LOSSES=0" >> "${STATE_FILE}"
        echo "BJ_PUSHES=0" >> "${STATE_FILE}"
    fi

    # shellcheck disable=SC1090
    source "${STATE_FILE}"
}

# ---------------------------------------------------------------------------
# Save current state variables back to file
# ---------------------------------------------------------------------------
save_state() {
    cat > "${STATE_FILE}" <<EOF
PET_NAME=${PET_NAME}
PET_TYPE=${PET_TYPE}
HUNGER=${HUNGER}
ENERGY=${ENERGY}
HAPPINESS=${HAPPINESS}
HEALTH=${HEALTH}
AGE_DAYS=${AGE_DAYS}
BORN_EPOCH=${BORN_EPOCH}
LAST_FED_EPOCH=${LAST_FED_EPOCH}
LAST_SLEPT_EPOCH=${LAST_SLEPT_EPOCH}
LAST_PLAYED_EPOCH=${LAST_PLAYED_EPOCH}
LAST_UPDATE_EPOCH=${LAST_UPDATE_EPOCH}
IS_SLEEPING=${IS_SLEEPING}
ALIVE=${ALIVE}
MOOD=${MOOD}
TOTAL_FEEDS=${TOTAL_FEEDS}
TOTAL_PLAYS=${TOTAL_PLAYS}
TOTAL_SLEEPS=${TOTAL_SLEEPS}
BJ_WINS=${BJ_WINS}
BJ_LOSSES=${BJ_LOSSES}
BJ_PUSHES=${BJ_PUSHES}
EOF
}

# ---------------------------------------------------------------------------
# Clamp a value between 0 and 100
# ---------------------------------------------------------------------------
clamp() {
    local val=$1
    if (( val < 0 )); then
        echo 0
    elif (( val > 100 )); then
        echo 100
    else
        echo "${val}"
    fi
}

# ---------------------------------------------------------------------------
# Calculate derived health from other stats
# ---------------------------------------------------------------------------
calc_health() {
    local h=$(( (HUNGER + ENERGY + HAPPINESS) / 3 ))
    echo "${h}"
}

# ---------------------------------------------------------------------------
# Determine mood based on stats
# ---------------------------------------------------------------------------
calc_mood() {
    local avg=$(( (HUNGER + ENERGY + HAPPINESS) / 3 ))
    if (( ALIVE == 0 )); then
        echo "dead"
    elif (( IS_SLEEPING == 1 )); then
        echo "sleeping"
    elif (( avg >= 80 )); then
        echo "ecstatic"
    elif (( avg >= 60 )); then
        echo "happy"
    elif (( avg >= 40 )); then
        echo "okay"
    elif (( avg >= 20 )); then
        echo "sad"
    else
        echo "miserable"
    fi
}

# ---------------------------------------------------------------------------
# Decay stats based on elapsed time (called by daemon and on load)
# ---------------------------------------------------------------------------
decay_stats() {
    local now
    now=$(date +%s)
    local elapsed=$(( now - LAST_UPDATE_EPOCH ))

    # Decay every 300 seconds (5 minutes) = 1 tick
    local ticks=$(( elapsed / 300 ))

    if (( ticks <= 0 )); then
        return
    fi

    if (( ALIVE == 0 )); then
        LAST_UPDATE_EPOCH=${now}
        save_state
        return
    fi

    # Hunger decays faster
    local hunger_loss=$(( ticks * 3 ))
    # Energy decays moderately (slower if sleeping)
    local energy_loss
    if (( IS_SLEEPING == 1 )); then
        # Sleeping restores energy
        local energy_gain=$(( ticks * 5 ))
        ENERGY=$(clamp $(( ENERGY + energy_gain )))
        # Check if fully rested - wake up
        if (( ENERGY >= 100 )); then
            IS_SLEEPING=0
        fi
        energy_loss=0
    else
        energy_loss=$(( ticks * 2 ))
    fi
    # Happiness decays slowly
    local happy_loss=$(( ticks * 1 ))

    HUNGER=$(clamp $(( HUNGER - hunger_loss )))
    ENERGY=$(clamp $(( ENERGY - energy_loss )))
    HAPPINESS=$(clamp $(( HAPPINESS - happy_loss )))
    HEALTH=$(calc_health)

    # Calculate age
    AGE_DAYS=$(( (now - BORN_EPOCH) / 86400 ))

    # Check if pet has perished from neglect
    if (( HUNGER <= 0 && ENERGY <= 0 && HAPPINESS <= 0 )); then
        ALIVE=0
        MOOD="dead"
    else
        MOOD=$(calc_mood)
    fi

    LAST_UPDATE_EPOCH=${now}
    save_state
}

