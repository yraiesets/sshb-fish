cmd_install_prompt() {
    local fish_conf_dir="${HOME}/.config/fish/conf.d"
    local fish_file="${fish_conf_dir}/sshb.fish"
    local marker="# SSHB-PROMPT-INTEGRATION"

    if grep -q "${marker}" "${fish_file}" 2>/dev/null; then
        echo -e "${YELLOW}SSH Buddy prompt is already installed in your Fish config${RESET}"
        return 0
    fi

    mkdir -p "${fish_conf_dir}"

    cat >> "${fish_file}" << 'FISHEOF'
# SSHB-PROMPT-INTEGRATION - SSH Buddy Tamagotchi prompt
# Shows pet status in right prompt and reacts to command success/failure
# Note: functions are defined unconditionally so they survive conf.d load order
# (PATH including ~/.local/bin is not yet set when conf.d files run)
function __sshb_postexec --on-event fish_postexec
    set -l last_exit $status
    if type -q sshb
        sshb react $last_exit $argv[1] 2>/dev/null
    end
end
function fish_right_prompt
    if type -q sshb
        sshb prompt 2>/dev/null
    end
end
# END-SSHB-PROMPT-INTEGRATION
FISHEOF

    echo -e "${GREEN}SSH Buddy prompt installed! Open a new terminal or run 'source ~/.config/fish/conf.d/sshb.fish'.${RESET}"
    echo -e "${DIM}Your right prompt will now show ${PET_NAME}'s status and reactions.${RESET}"
}

cmd_uninstall_prompt() {
    local fish_file="${HOME}/.config/fish/conf.d/sshb.fish"
    local start_marker="# SSHB-PROMPT-INTEGRATION"

    if [[ ! -f "${fish_file}" ]] || ! grep -q "${start_marker}" "${fish_file}" 2>/dev/null; then
        echo -e "${YELLOW}SSH Buddy prompt is not installed in your Fish config${RESET}"
        return 0
    fi

    rm -f "${fish_file}"
    echo -e "${GREEN}SSH Buddy prompt removed. Open a new terminal to apply changes.${RESET}"
}

cmd_version() {
    echo -e "sshb v${VERSION}"
}

# ---------------------------------------------------------------------------
# Main entry point
# ---------------------------------------------------------------------------
main() {
    init_dir
    local cmd="${1:-}"
    shift 2>/dev/null || true

    case "${cmd}" in
        feed)              cmd_feed ;;
        play)              cmd_play ;;
        sleep)             cmd_sleep ;;
        wake)              cmd_wake ;;
        status|"")         show_status ;;
        mini)              cmd_mini ;;
        prompt)            cmd_prompt ;;
        react)             cmd_react "$@" ;;
        interactive|i)     cmd_interactive ;;
        rename)            cmd_rename "$*" ;;
        revive)            cmd_revive ;;
        reset)             cmd_reset ;;
        install-prompt)    load_state; cmd_install_prompt ;;
        uninstall-prompt)  cmd_uninstall_prompt ;;
        version|-v)        cmd_version ;;
        help|-h|--help)    cmd_help ;;
        *)
            echo -e "${RED}Unknown command: ${cmd}${RESET}"
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
