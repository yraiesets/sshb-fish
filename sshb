cmd_play() {
    load_state
    decay_stats

    if (( ALIVE == 0 )); then
        echo -e "${RED}Your buddy is no longer with us. Use 'sshb revive' first.${RESET}"
        return 1
    fi

    if (( IS_SLEEPING == 1 )); then
        echo -e "${YELLOW}${PET_NAME} is sleeping. Let them rest or use 'sshb wake' first.${RESET}"
        return 1
    fi

    if (( ENERGY < 10 )); then
        echo -e "${YELLOW}${PET_NAME} is too tired to play. Try 'sshb sleep' first.${RESET}"
        show_cat "sad"
        return 1
    fi

    # -- Start a hand of Blackjack --
    bj_shuffle
    BJ_PLAYER_HAND=()
    BJ_DEALER_HAND=()

    # Deal two cards each
    BJ_PLAYER_HAND+=("$(bj_draw)")
    BJ_DEALER_HAND+=("$(bj_draw)")
    BJ_PLAYER_HAND+=("$(bj_draw)")
    BJ_DEALER_HAND+=("$(bj_draw)")

    local p_val d_val
    p_val=$(bj_hand_value BJ_PLAYER_HAND)

    # Check natural blackjack
    if (( p_val == 21 )); then
        clear
        ascii_cat_impressed
        bj_show_table "yes"
        echo -e "  ${GREEN}${BOLD}BLACKJACK! Natural 21!${RESET}"
        echo ""
        bj_win_comment
        HAPPINESS=$(clamp $(( HAPPINESS + 30 )))
        ENERGY=$(clamp $(( ENERGY - 5 )))
        BJ_WINS=$(( BJ_WINS + 1 ))
        TOTAL_PLAYS=$(( TOTAL_PLAYS + 1 ))
        LAST_PLAYED_EPOCH=$(date +%s)
        HEALTH=$(calc_health)
        MOOD=$(calc_mood)
        save_state
        echo ""
        return 0
    fi

    # Player turn
    while true; do
        clear
        ascii_cat_dealer
        bj_show_table "no"
        bj_taunt
        echo ""
        echo -e "  ${BOLD}[h]${RESET} Hit   ${BOLD}[s]${RESET} Stand"
        echo ""
        echo -n "  > "
        read -r -n 1 action
        echo ""

        case "${action}" in
            h|H)
                BJ_PLAYER_HAND+=("$(bj_draw)")
                p_val=$(bj_hand_value BJ_PLAYER_HAND)
                if (( p_val > 21 )); then
                    clear
                    ascii_cat_laugh
                    bj_show_table "yes"
                    echo -e "  ${RED}${BOLD}BUST! You went over 21!${RESET}"
                    echo ""
                    bj_lose_comment
                    HAPPINESS=$(clamp $(( HAPPINESS + 5 )))
                    ENERGY=$(clamp $(( ENERGY - 10 )))
                    BJ_LOSSES=$(( BJ_LOSSES + 1 ))
                    TOTAL_PLAYS=$(( TOTAL_PLAYS + 1 ))
                    LAST_PLAYED_EPOCH=$(date +%s)
                    HEALTH=$(calc_health)
                    MOOD=$(calc_mood)
                    save_state
                    echo ""
                    return 0
                fi
                ;;
            s|S)
                break
                ;;
            *)
                echo -e "  ${YELLOW}Press h to hit or s to stand.${RESET}"
                sleep 1
                ;;
        esac
    done

    # Dealer turn
    d_val=$(bj_hand_value BJ_DEALER_HAND)
    while (( d_val < 17 )); do
        BJ_DEALER_HAND+=("$(bj_draw)")
        d_val=$(bj_hand_value BJ_DEALER_HAND)
    done

    p_val=$(bj_hand_value BJ_PLAYER_HAND)
    d_val=$(bj_hand_value BJ_DEALER_HAND)

    clear
    bj_show_table "yes"

    # Determine winner
    if (( d_val > 21 )); then
        ascii_cat_impressed
        echo -e "  ${GREEN}${BOLD}Dealer busts! You win!${RESET}"
        echo ""
        bj_win_comment
        HAPPINESS=$(clamp $(( HAPPINESS + 25 )))
        ENERGY=$(clamp $(( ENERGY - 5 )))
        BJ_WINS=$(( BJ_WINS + 1 ))
    elif (( p_val > d_val )); then
        ascii_cat_smug
        echo -e "  ${GREEN}${BOLD}You win! ${p_val} beats ${d_val}!${RESET}"
        echo ""
        bj_win_comment
        HAPPINESS=$(clamp $(( HAPPINESS + 25 )))
        ENERGY=$(clamp $(( ENERGY - 5 )))
        BJ_WINS=$(( BJ_WINS + 1 ))
    elif (( d_val > p_val )); then
        ascii_cat_laugh
        echo -e "  ${RED}${BOLD}Dealer wins! ${d_val} beats ${p_val}!${RESET}"
        echo ""
        bj_lose_comment
        HAPPINESS=$(clamp $(( HAPPINESS + 5 )))
        ENERGY=$(clamp $(( ENERGY - 10 )))
        BJ_LOSSES=$(( BJ_LOSSES + 1 ))
    else
        ascii_cat_okay
        echo -e "  ${YELLOW}${BOLD}Push! Both have ${p_val}.${RESET}"
        echo ""
        bj_push_comment
        HAPPINESS=$(clamp $(( HAPPINESS + 10 )))
        ENERGY=$(clamp $(( ENERGY - 5 )))
        BJ_PUSHES=$(( BJ_PUSHES + 1 ))
    fi

    TOTAL_PLAYS=$(( TOTAL_PLAYS + 1 ))
    LAST_PLAYED_EPOCH=$(date +%s)
    HUNGER=$(clamp $(( HUNGER - 5 )))
    HEALTH=$(calc_health)
    MOOD=$(calc_mood)
    save_state
    echo ""
}


