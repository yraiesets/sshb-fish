# Pick which roast pool to use based on command name
pick_roast() {
    local cmd_name="$1"
    case "${cmd_name}" in
        make|cmake|ninja|gcc|g++|cc|clang)  roast_make ;;
        docker|docker-compose|podman)        roast_docker ;;
        git)                                  roast_git ;;
        npm|npx|yarn|pnpm|bun)              roast_npm ;;
        pip|pip3|pipenv|poetry)              roast_pip ;;
        ssh|scp|sftp|rsync)                  roast_ssh ;;
        python|python3)                       roast_python ;;
        cargo|rustc)                          roast_cargo ;;
        *)                                    roast_generic ;;
    esac
}

pick_praise() {
    local cmd_name="$1"
    case "${cmd_name}" in
        make|cmake|ninja|gcc|g++|cc|clang)  praise_make ;;
        docker|docker-compose|podman)        praise_docker ;;
        git)                                  praise_git ;;
        *)                                    praise_generic ;;
    esac
}

# Commands that are too boring/frequent to react to
is_boring_command() {
    local cmd_name="$1"
    case "${cmd_name}" in
        ls|cd|pwd|echo|cat|clear|history|exit|source|export|alias|unalias)
            return 0 ;;
        fg|bg|jobs|type|which|whoami|id|true|false|test|"[")
            return 0 ;;
        sshb|__sshb*)
            return 0 ;;
        ""|" ")
            return 0 ;;
    esac
    return 1
}

# Main react handler - called from PROMPT_COMMAND
cmd_react() {
    local exit_code="${1:-0}"
    local cmd_name="${2:-}"

    # Strip leading whitespace and get first word only
    cmd_name=$(echo "${cmd_name}" | sed 's/^[[:space:]]*//' | awk '{print $1}')

    # Skip boring commands
    if is_boring_command "${cmd_name}"; then
        return 0
    fi

    # Only react sometimes (30% chance for success, 60% chance for failure)
    local roll=$(( RANDOM % 100 ))

    if (( exit_code != 0 )); then
        # Failed command - higher chance to roast
        if (( roll < 60 )); then
            local roast
            roast=$(pick_roast "${cmd_name}")
            echo -e "${MAGENTA}  /\\_/\\\\${RESET}"
            echo -e "${MAGENTA} ( -w- )${RESET}  ${DIM}${roast}${RESET}"
        fi
    else
        # Successful command - lower chance to praise
        if (( roll < 30 )); then
            local praise
            praise=$(pick_praise "${cmd_name}")
            echo -e "${CYAN}  /\\_/\\\\${RESET}"
            echo -e "${CYAN} ( ^.^ )${RESET}  ${DIM}${praise}${RESET}"
        fi
    fi
}


